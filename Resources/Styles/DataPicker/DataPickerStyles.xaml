<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:Almacen_Sistema.Resources.Helpers.DataPicker___Control">
    <Style x:Key="CustomMaterialDatePickerStyle" TargetType="{x:Type DatePicker}" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">

        <Setter Property="BorderBrush" Value="#bdbdbd"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="helpers:DatePickerHelper.DisableManualInput" Value="True"/>
        <Setter Property="Language" Value="es-MX"/>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#bdbdbd"/>
            </Trigger>

            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="#bdbdbd"/>
            </Trigger>
        </Style.Triggers>
        
    </Style>
</ResourceDictionary>