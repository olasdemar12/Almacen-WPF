<UserControl x:Class="Almacen_Sistema.UI.Panels.Movements.ProductSelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Panels.Movements"
              xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid>
        <controls:PanelControl Width="500" Height="600" Title="Productos Registrados"
                                   ShowCloseButton="True" ShowBackButton="False">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!--Seccion para buscar y filtrar productos-->
                <Grid Grid.Row="0" Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <!--Barra de busqueda-->
                    <controls:SearchBarControl Grid.Column="0" HintText="Buscar Producto..."/>
                    
                    <!--Filtro de categorias-->
                    <ComboBox Grid.Column="1" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" Width="150"
                              Padding="15,10" Margin="10,0,0,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Categorías"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"/>

                </Grid>
                
                <!--Lista para mostrar los productos registrados-->
                <Border Grid.Row="1" Height="42" Margin="2,0,2,0"
                    VerticalAlignment="Top"
                    Background="#4A80C0"
                    Panel.ZIndex="0"/>

                <DataGrid Grid.Row="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Style="{StaticResource DataGridStyleGeneral}"
                      ColumnHeaderStyle="{StaticResource DataGridHead}"
                      CellStyle="{StaticResource DataGridCellConfig}"
                      RowStyle="{StaticResource DataGridRowConfig}"
                      Padding="0,0,0,0"
                      
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="1,1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                            
                      RowHeight="60"
                      Panel.ZIndex="1"
                      Background="Transparent">


                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Producto"
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Width="*" />

                        <DataGridTextColumn Header="Categoría" 
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Width="*" />

                        <DataGridTextColumn Header="Código de Barras"
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Binding="{Binding BarCode}" 
                                        Width="*" />
                    </DataGrid.Columns>

                </DataGrid>

            </Grid>
        </controls:PanelControl>
    </Grid>
</UserControl>
