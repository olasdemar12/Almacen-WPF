<UserControl x:Class="Almacen_Sistema.UI.Forms.Movements_2.ExitFormControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Forms.Movements_2"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Forms.Movements.ExitForm"
             d:DataContext="{d:DesignInstance Type=vm:ExitFormViewModel,IsDesignTimeCreatable=False}"
             mc:Ignorable="d">
    <controls:PanelControl Width="500" Height="550" Title="{Binding TitleForm}" IsEnabled="{Binding FormEnabled}"
                           ShowBackButton="{Binding ShowButtonBackActive}" ShowCloseButton="False" CommandBackButton="{Binding CloseFormCommand}">
        <StackPanel>
            
            <!--Targeta que muestra la informacion del Producto seleccionado-->
            <Border Background="White" BorderBrush="#bdbdbd" Margin="10"
                    Height="140" BorderThickness="2" CornerRadius="4">
                <StackPanel>
                    <!--Informacion del Producto-->
                    <Border Background="#e0e0e0" BorderBrush="#e0e0e0" Height="35"
                            CornerRadius="2">
                        <TextBlock Text="Informacion del Producto" Foreground="#212121" FontSize="16"
                                   FontFamily="Segoe UI" Margin="10,8,0,0"/>
                    </Border>
                    
                    <!--Nombre del Producto-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" HorizontalAlignment="Left" Text="Nombre" Foreground="#616161"
                                   FontSize="16" FontFamily="Segoe UI" Margin="10,5,0,0"/>

                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TransactionObject.ProductName}" Foreground="#616161"
                                   FontSize="16" FontFamily="Segoe UI" Margin="0,5,10,0"/>

                    </Grid>
                    <Border Height="2" Margin="5,5,5,0" Background="#e0e0e0"/>

                    <!--Unidades, Kilogramos o Piezas del Producto en Stock-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" HorizontalAlignment="Left" Text="Unidades Totales" Foreground="#616161"
                                   FontSize="16" FontFamily="Segoe UI" Margin="10,5,0,0"/>

                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Foreground="#616161"
                                   FontSize="16" FontFamily="Segoe UI" Margin="0,5,10,0">
                            <Run Text="{Binding TakenAmount}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TransactionObject.Quantity}"/>
                        </TextBlock>

                    </Grid>
                    <Border Height="2" Margin="5,5,5,0" Background="#e0e0e0"/>

                    <!--Fecha y Hora en el cual se realiza el registro-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" HorizontalAlignment="Left" Text="Fecha y Hora de Registro" Foreground="#616161"
                                   FontSize="16" FontFamily="Segoe UI" Margin="10,5,0,0"/>

                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding TransactionObject.RegisterDate,StringFormat={}{0:dd-MM-yyyy hh:mm:ss}}" Foreground="#616161"
                                   FontSize="16" FontFamily="Segoe UI" Margin="0,5,10,0"/>

                    </Grid>



                </StackPanel>

            </Border>
            
            <!--Registro de Unidades para la salida siempre y cuando exista stock almacenado.-->
            <TextBlock Text="Cantidad a Retirar" Foreground="#212121" FontSize="16"
                                   FontFamily="Segoe UI" Margin="10,0,0,0"/>
            <controls:InputQuantitiesControl Margin="10,5,10,10"
                                             Quantity="{Binding AmountExit,
                                             Mode=TwoWay,
                                             UpdateSourceTrigger=PropertyChanged,
                                             ValidatesOnNotifyDataErrors=True,
                                             NotifyOnValidationError=True}"/>

            <!--Observaciones del Registro-->
            <TextBlock Text="Observaciones del Registro" Foreground="#212121" FontSize="16"
                                   FontFamily="Segoe UI" Margin="10,0,0,0"/>
            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
             BorderBrush="#bdbdbd" Background="White" BorderThickness="2"         
             materialDesign:HintAssist.Hint="(Opcional)"
             materialDesign:HintAssist.IsFloating="False"
             Margin="10,5,10,0" FontFamily="Segoe UI" FontSize="16"
             materialDesign:ValidationAssist.Background="White"
             AcceptsReturn="True" Padding="10"
             TextWrapping="Wrap" VerticalContentAlignment="Top"
             VerticalScrollBarVisibility="Auto"
             MinHeight="130"
             Text="{Binding Notes,
             Mode=TwoWay,UpdateSourceTrigger=Default,
             ValidatesOnNotifyDataErrors=True,NotifyOnValidationError=True}"/>
            
            <!--Botones para cancelar o guardar el registro-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button Content="Cancelar" Height="50" Padding="10,0,10,0" Background="#BDBDBD"
                        BorderBrush="#BDBDBD" Foreground="White" FontFamily="Segoe UI"
                        FontWeight="Normal" FontSize="22" materialDesign:ButtonAssist.CornerRadius="5"
                        Command="{Binding CloseFormCommand}"/>
                
                <controls:LoadingButtonControl Width="auto" Height="50"
                                                   ButtonContent="{Binding ContentButton}"
                                                   IsLoading="{Binding LoadingAction}"
                                                   Margin="5,0,0,0"
                                                   Padding="10,0,10,0"
                                                   ButtonColor="#1c4d8d"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="Normal"/>
            </StackPanel>
             
        </StackPanel>
    </controls:PanelControl>

</UserControl>
