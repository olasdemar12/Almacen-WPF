<UserControl x:Class="StockMasterControls.DeleteDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:StockMasterControls"
             mc:Ignorable="d"
             x:Name="Root">
    <Grid>
        <Border Width="600" Height="auto" Background="White" CornerRadius="10" IsEnabled="{Binding IsEnable, ElementName=Root}">

            <!--Titulo del Dialogo-->
            <StackPanel Orientation="Vertical">

                <!--Titulo del Dialogo-->
                <Border BorderThickness="0,0,0,3" BorderBrush="#E0E0E0">
                    <StackPanel Orientation="Horizontal">
                        
                        <materialDesign:PackIcon Width="30" Height="30" Margin="20,20,20,0"
                                           Foreground="Red" Kind="TrashCanOutline"/>
                        
                        <!--Titulo 1-->
                        <TextBlock Text="{Binding Title, ElementName=Root}" FontSize="24"
                               Foreground="#212121" FontFamily="Segoe UI"
                               FontWeight="Bold" Margin="0,20,20,10"/>
                        
                    </StackPanel>
                </Border>
                
                <!--Contenido del Panel-->
                <Border BorderThickness="0,0,0,3" BorderBrush="#E0E0E0">
                    <StackPanel>

                        <!--Sub titulo-->
                        <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                                   FontSize="18" FontFamily="Segoe UI" Foreground="#212121"
                                   Margin="20,10,0,0"/>

                        <!--Mensaje-->
                        <TextBlock FontSize="18" FontFamily="Segoe UI" 
                                   Foreground="#212121"
                                   TextWrapping="Wrap"
                                   Margin="20,20,20,20">
                            <Run Text="{Binding Normal1, ElementName=Root}"/>
                            <Run Text="{Binding Negrita1, ElementName=Root}" FontWeight="Bold" />
                            <Run Text="{Binding Normal2, ElementName=Root}"/>
                            <Run Text="{Binding Negrita2, ElementName=Root}" FontWeight="Bold" />
                            <Run Text="{Binding Normal3, ElementName=Root}"/>
                            <Run Text="{Binding Negrita3, ElementName=Root}" FontWeight="Bold" />
                        </TextBlock>

                    </StackPanel>
                </Border>
                
                <!--Buttons-->

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="30">

                    <Button Width="120" Height="40" Margin="0,0,0,0"
                            materialDesign:ButtonAssist.CornerRadius="5"
                            Foreground="White" BorderBrush="#BDBDBD"
                            Content="Cancelar" Background="#BDBDBD" FontSize="22"
                            Command="{Binding CancelCommand, ElementName=Root}"/>

                    <controls:LoadingButtonControl Width="auto" Height="40"
                                                   ButtonContent="Eliminar"
                                                   IsLoading="{Binding IsLoading, ElementName=Root}"
                                                   Command="{Binding DeleteCommand, ElementName=Root}"
                                                   Padding="20,0,20,0"
                                                   ButtonColor="Red"
                                                   Foreground="White" 
                                                   FontSize="22"
                                                   FontWeight="Normal"/>

                </StackPanel>
            </StackPanel>
            
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
        </Border>
    </Grid>
</UserControl>
