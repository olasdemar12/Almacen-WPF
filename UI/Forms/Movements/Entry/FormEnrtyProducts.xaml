<UserControl x:Class="Almacen_Sistema.UI.Forms.Movements.Entry.FormEnrtyProducts"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Forms.Movements.Entry"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Forms.Movements"
             d:DataContext="{d:DesignInstance Type=vm:EntryFormViewModel,IsDesignTimeCreatable=False}"
             mc:Ignorable="d">
    <controls:PanelControl Title="{Binding TitleForm}"
                            Width="500"
                            Height="575">
        <StackPanel>
            <!--Producto seleccionado-->
            <Label Content="Producto Seleccionado" 
                      FontSize="16" FontWeight="Normal"
                      FontFamily="Segoe UI" Foreground="#212121"
                      Margin="10,10,10,0"/>
            <Border Margin="10,0,10,0" Height="45" Background="#e0e0e0"
                        BorderBrush="#bdbdbd" BorderThickness="2"
                        CornerRadius="5">
                <TextBlock Text="{Binding MovementObject.ProductName}" FontSize="16" Margin="10"
                               Foreground="#212121" FontFamily="Segoe UI"/>
            </Border>

            <!--Fecha y Hora del registro de entrada-->
            <Label Content="Fecha y Hora del registro"
                        FontSize="16" FontWeight="Normal"
                        FontFamily="Segoe UI" Foreground="#212121"
                        Margin="10,10,10,0"/>
            <Border Margin="10,0,10,0" Height="45" Background="#e0e0e0"
                 BorderBrush="#bdbdbd" BorderThickness="2"
                    CornerRadius="5">
                <TextBlock Text="{Binding MovementObject.RegisterDate,StringFormat={}{0:dd-MM-yyyy hh:mm:ss}}" FontSize="16" Margin="10"
                    Foreground="#212121" FontFamily="Segoe UI"/>
            </Border>

            <!--Registro de unidades, piezas o kilogramos registrados-->
            <TextBlock Text="Cantidad Recibida" Foreground="#212121" FontSize="16"
                                   FontFamily="Segoe UI" Margin="10,10,0,0"/>
            <controls:InputQuantitiesControl Margin="10,5,10,10"
                                             Quantity="{Binding TotalAmount,
                                             Mode=TwoWay,
                                             UpdateSourceTrigger=PropertyChanged,
                                             ValidatesOnNotifyDataErrors=True,
                                             NotifyOnValidationError=True}"/>


            <!--Observaciones del Registro-->
            <TextBlock Text="Observaciones del Registro" Foreground="#212121" FontSize="16"
                                   FontFamily="Segoe UI" Margin="10,0,0,0"/>
            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
             Text="{Binding Notes,Mode=TwoWay,UpdateSourceTrigger=Default,ValidatesOnNotifyDataErrors=True,NotifyOnValidationError=True}"        
             BorderBrush="#bdbdbd" Background="White" BorderThickness="2"         
             materialDesign:HintAssist.Hint="(Opcional)"
             materialDesign:HintAssist.IsFloating="False"
             Margin="10,5,10,0" FontFamily="Segoe UI" FontSize="16"
             materialDesign:ValidationAssist.Background="White"
             AcceptsReturn="True" Padding="10"
             TextWrapping="Wrap" VerticalContentAlignment="Top"
             VerticalScrollBarVisibility="Auto"
             Height="130"/>

            <!--Botones para cancelar o guardar el registro-->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button Content="Cancelar" Height="50" Padding="10,0,10,0" Background="#BDBDBD"
                        BorderBrush="#BDBDBD" Foreground="White" FontFamily="Segoe UI"
                        FontWeight="Normal" FontSize="22" materialDesign:ButtonAssist.CornerRadius="5"
                        Command="{Binding CloseFormCommand}"/>

                <controls:LoadingButtonControl Width="auto" Height="50"
                                                   ButtonContent="{Binding ContentButton}"
                                                   IsLoading="False"
                                                   Margin="5,0,0,0"
                                                   Padding="10,0,10,0"
                                                   ButtonColor="#1c4d8d"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="Normal"
                                                   Command="{Binding SaveEntryCommand}"/>
            </StackPanel>

        </StackPanel>

        <controls:PanelControl.Style>
            <Style TargetType="{x:Type controls:PanelControl}">
                <Setter Property="ShowBackButton" Value="False"/>
                <Setter Property="ShowCloseButton" Value="False"/>
                <Setter Property="IsEnabled" Value="{Binding IsEnable}"/>
                <Setter Property="CommandBackButton" Value="{Binding CloseFormCommand}"/>

                <Style.Triggers>
                    <DataTrigger Binding="{Binding ActionForm}" Value="Add">
                        <Setter Property="ShowBackButton" Value="True"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </controls:PanelControl.Style>
    </controls:PanelControl>
</UserControl>
