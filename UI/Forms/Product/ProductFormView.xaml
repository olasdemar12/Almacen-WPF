<UserControl x:Class="Almacen_Sistema.UI.Forms.Product.ProductFormView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Forms.Product"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Forms"
             d:DataContext="{d:DesignInstance Type=vm:ProductFormViewModel,IsDesignTimeCreatable=False}"
             mc:Ignorable="d">
    <Grid>
        <controls:PanelControl Title="Agregar Nuevo Producto"
                               Width="600" Height="auto" ShowBackButton="False"
                               ShowCloseButton="False" IsEnabled="True">
            <StackPanel IsEnabled="{Binding IsEnable}">
                <!-- Campo para el nombre del Producto -->
                <TextBox  Style="{StaticResource MaterialDesignOutlinedTextBox}"
                          Text="{Binding ProductName,UpdateSourceTrigger=Default,ValidatesOnNotifyDataErrors=True}"
                          FontFamily="Segoe UI" FontSize="22" Padding="13"
                          Margin="10,20,10,15"
                          materialDesign:HintAssist.Hint="Nombre del Producto"
                          materialDesign:HintAssist.HintPaddingBrush="White"
                          materialDesign:ValidationAssist.Background="White"
                          materialDesign:ValidationAssist.FontSize="16"
                          materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
                          BorderBrush="#bdbdbd"/>
                
                <!--Campo para codigo de barra-->
                <TextBox  Style="{StaticResource MaterialDesignOutlinedTextBox}"
                          Text="{Binding BarCode,UpdateSourceTrigger=Default,ValidatesOnNotifyDataErrors=True}"
                          FontFamily="Segoe UI" FontSize="22" Padding="13"
                          Margin="10,20,10,15" 
                          materialDesign:HintAssist.Hint="Código de Barras"
                          materialDesign:HintAssist.HintPaddingBrush="White"
                          materialDesign:ValidationAssist.Background="White"
                          materialDesign:ValidationAssist.FontSize="16"
                          materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
                          BorderBrush="#bdbdbd"/>
                
                <!-- Selectores de Categorias y Tipo de Venta -->
                <Grid  Margin="10,20,10,15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!--Selector de Categorias-->
                    <ComboBox FontSize="22" FontFamily="Segoe UI" Grid.Column="0"
          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
          Padding="15,10" Margin="0,0,10,0"
          materialDesign:HintAssist.Hint="Categorías"
          materialDesign:HintAssist.HintPaddingBrush="White"
          materialDesign:ValidationAssist.Background="White"
          materialDesign:ValidationAssist.FontSize="16"
          ItemsSource="{Binding Categories}"
          SelectedValue="{Binding IdCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
          SelectedValuePath="IdCategoria"
          DisplayMemberPath="NombreCategoria">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                                <Setter Property="BorderBrush" Value="#bdbdbd" />

                                <Style.Triggers>
                                    <Trigger Property="Validation.HasError" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignValidationErrorBrush}" />
                                        <Setter Property="BorderThickness" Value="2" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <!--Selector de Tipo de Venta-->
                    <ComboBox FontSize="22" FontFamily="Segoe UI" Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                              Padding="15,10" Margin="10,0,0,0"
                              materialDesign:HintAssist.Hint="Tipo de Venta"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:ValidationAssist.Background="White"
                              materialDesign:ValidationAssist.FontSize="16"
                              ItemsSource="{Binding Source={x:Static controls:NotificationServiceControl.Instance}, Path=SaleType}"
                              SelectedValue="{Binding SaleType,
                        Mode=TwoWay,
                        UpdateSourceTrigger=PropertyChanged,
                        ValidatesOnNotifyDataErrors=True}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                                <Setter Property="BorderBrush" Value="#bdbdbd"/>
                                <Style.Triggers>
                                    <!-- Cuando hay error -->
                                    <Trigger Property="Validation.HasError" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignValidationErrorBrush}" />
                                        <Setter Property="BorderThickness" Value="2" />
                                    </Trigger>

                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </Grid>

                <!-- TextBox de Precio de compra y venta -->
                <Grid Margin="10,20,10,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!--Precio de Compra-->
                    <controls:TextBoxPrecieControl Grid.Column="0" Hint="Precio de Compra" Margin="0,0,10,0"
                                                   Value="{Binding PurchasePrice,UpdateSourceTrigger=Default,ValidatesOnNotifyDataErrors=True}"/>

                    <!--Precio de Venta-->
                    <controls:TextBoxPrecieControl Grid.Column="1" Hint="Precio de Venta" Margin="10,0,0,0"
                                                   Value="{Binding SalePrice,UpdateSourceTrigger=Default,ValidatesOnNotifyDataErrors=True}"/>
                </Grid>
                
                <!--Botones para accionar el Formulario-->
                <StackPanel Orientation="Horizontal" Margin="10,20,10,15" HorizontalAlignment="Right">
                    
                    <!--Boton de Cancelar-->
                    <Button Content="Cancelar" Width="auto" Height="50"
                            Padding="20,0,20,0"
                            Background="#BDBDBD"
                            BorderBrush="#BDBDBD"
                            Foreground="White"
                            FontSize="22"
                            FontWeight="Normal"
                            materialDesign:ButtonAssist.CornerRadius="5"
                            Command="{Binding CloseFormCommand}"
                            />

                    <!--Boton para accionar eventos de guardar, editar u otros-->
                    <controls:LoadingButtonControl Width="auto" Height="50"
                                                   ButtonContent="{Binding ButtonContent}"
                                                   IsLoading="{Binding IsLoading}"
                                                   Command="{Binding ActionFormCommand}"
                                                   Margin="20,0,10,0"
                                                   Padding="20,0,20,0"
                                                   ButtonColor="#1c4d8d"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="Normal"/>

                </StackPanel>
            </StackPanel>
        </controls:PanelControl>
    </Grid>
</UserControl>
