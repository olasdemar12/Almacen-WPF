<Page x:Class="Almacen_Sistema.UI.Views.MovimientosView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Almacen_Sistema.UI.Views"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:StockMasterControls"
      xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Pages"
      xmlns:helpers="clr-namespace:Almacen_Sistema.Resources.Helpers.DataPicker___Control"
      d:DataContext="{d:DesignInstance Type=vm:MovementsViewModel,IsDesignTimeCreatable=False}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MovimientosView">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Barra de busquedam filtros y botones para acciones: Entrada y Salida -->
            <Border Background="White" Grid.Row="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                    Width="auto" Height="80" CornerRadius="0,0,5,5"
                    Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" 
                                      Direction="270" 
                                      ShadowDepth="2" 
                                      Opacity="0.5" 
                                      BlurRadius="10" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Barra de Busqueda -->
                    <controls:SearchBarControl
                        Margin="5,15,5,15"
                        HintText="Buscar Producto"
                        SearchText="{Binding SearchProduct}"
                        SearchCommand="{Binding SearchProductsCommand}"/>

                    <!--Filtro de Tipo de Movimiento-->
                    <ComboBox Grid.Column="1" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                              Padding="15,10" Margin="5,15,5,15"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Tipo de Movimiento"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"/>
                    
                    <!--Intervalos de fechas: Fecha Inicio -->
                    <DatePicker Grid.Column="2" Style="{StaticResource CustomMaterialDatePickerStyle}"
                                Margin="5,15,5,15"/>

                    <!--Intervalos de fechas: Fecha Fin -->
                    <DatePicker Grid.Column="3" Style="{StaticResource CustomMaterialDatePickerStyle}"
                                Margin="5,15,5,15"/>
                    
                    <!--Boton para registrar Entradas-->
                    <controls:IconTextButtonControl Grid.Column="4" 
                        Width="140" Height="50" Padding="0"
                        Margin="5,0,5,0"
                        Icon="Login" Text="Entrada"
                        ColorButton="#1c4d8d" ContentColorButton="White"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Command="{Binding EntryMovementCommand}"/>

                    <!--Boton para registrar Salida-->
                    <controls:IconTextButtonControl Grid.Column="5"
                        Margin="5,0,5,0" Padding="0"
                        Width="125" Height="50"
                        Icon="Logout" Text="Salida"
                        ColorButton="#1c4d8d" ContentColorButton="White"
                        materialDesign:ButtonAssist.CornerRadius="10"/>
                </Grid>
                
            </Border>

            <!--Tabla quen muestra la lista de Movimientos-->
            <Border Grid.Row="1" Height="42"
                    VerticalAlignment="Top"
                    Background="#4A80C0"
                    Panel.ZIndex="0"/>
            
            <DataGrid x:Name="ProductsGrid" Grid.Row="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Style="{StaticResource DataGridStyleGeneral}"
                      ColumnHeaderStyle="{StaticResource DataGridHead}"
                      CellStyle="{StaticResource DataGridCellConfig}"
                      RowStyle="{StaticResource DataGridRowConfig}"
                      ItemsSource="{Binding ProductsViewItems}"
                      Padding="0,0,0,0"
          
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="1,1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                
                      RowHeight="60"
                      Panel.ZIndex="1"
                      Background="Transparent">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Fecha"
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*" />

                    <DataGridTextColumn Header="Movimiento" 
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*" />

                    <DataGridTextColumn Header="Producto"
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*" />

                    <DataGridTextColumn Header="Cantidad"
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*" />

                    <DataGridTextColumn Header="Notas"
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*" />

                    <DataGridTemplateColumn Header="Acciones" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                </DataGrid.Columns>

            </DataGrid>

        </Grid>
    </Grid>
</Page>
