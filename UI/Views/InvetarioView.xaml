<Page x:Class="Almacen_Sistema.UI.Views.InvetarioView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Almacen_Sistema.UI.Views"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:StockMasterControls"
      xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Pages.Inventory"
      d:DataContext="{d:DesignInstance Type=vm:InventoryViewModel,IsDesignTimeCreatable=False}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="InvetarioView">
    <Grid>
        <Grid>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--Barra de busqueda y filtros-->
                <Border Background="White" Grid.Row="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                    Width="auto" Height="80" CornerRadius="0,0,5,5"
                    Margin="0,0,0,10">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" 
                                      Direction="270" 
                                      ShadowDepth="2" 
                                      Opacity="0.5" 
                                      BlurRadius="10" />
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Barra de Busqueda -->
                        <controls:SearchBarControl Grid.Column="0"
                        Margin="5,15,5,15"
                        HintText="Buscar Producto"
                        SearchText="{Binding SearchTextProduct}"/>

                        <!--Filtro de Categorias-->
                        <ComboBox Grid.Column="1" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                              Padding="15,10" Margin="5,15,5,15"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Categoría"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"
                              ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding IdCategorySelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="IdCategoria"
                              DisplayMemberPath="NombreCategoria"/>
                        
                        <!--Estado del Stock-->
                        <ComboBox Grid.Column="2" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                              Padding="15,10" Margin="5,15,5,15"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Tipo de Movimiento"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"
                              ItemsSource="{Binding StateStockOptions}"
                              SelectedItem="{Binding SelectedStateStock, Mode=TwoWay}"/>

                        <!--Intervalos de fechas: Fecha Inicio -->
                        <DatePicker Grid.Column="3" Style="{StaticResource CustomMaterialDatePickerStyle}"
                                Margin="5,15,5,15" materialDesign:HintAssist.Hint="Fecha de Inicio"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                SelectedDate="{Binding StarDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                DisplayDateEnd="{Binding EndDate}"/>

                        <!--Intervalos de fechas: Fecha Fin -->
                        <DatePicker Grid.Column="4" Style="{StaticResource CustomMaterialDatePickerStyle}"
                                Margin="5,15,5,15" materialDesign:HintAssist.Hint="Fecha de Fin"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                SelectedDate="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                DisplayDateStart="{Binding StarDate}"/>
                    </Grid>

                </Border>

                <!--Tabla quen muestra la lista de Movimientos-->
                <Border Grid.Row="1" Height="40.5" Width="30"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Background="#4A80C0"
                    Panel.ZIndex="0"/>
                <DataGrid Grid.Row="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Style="{StaticResource DataGridStyleGeneral}"
                      ColumnHeaderStyle="{StaticResource DataGridHead}"
                      CellStyle="{StaticResource DataGridCellConfig}"
                      RowStyle="{StaticResource DataInventoryGridConfing}"
                      ItemsSource="{Binding InventoryItemsView}"
                      SelectedItem="{Binding SelectedInventoryRow,Mode=TwoWay}"
                      SelectionMode="Single"
                      AutoGenerateColumns="False"
                      Padding="0,0,0,0"
          
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="1,1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                
                      RowHeight="60"
                      Panel.ZIndex="1"
                      Background="Transparent">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Producto"
                            ElementStyle="{StaticResource TextFillInventoryDataGrid}"
                            Binding="{Binding ProductName}"
                            Width="*"/>

                        <DataGridTextColumn Header="Categoría"
                            Binding="{Binding CategoryName}"
                            ElementStyle="{StaticResource TextFillInventoryDataGrid}"
                            Width="*"/>

                        <DataGridTemplateColumn Header="Stock Actual"
                            Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Border Style="{StaticResource StatusInventoryBorderStyle}">
                                        <TextBlock Text="{Binding TotalStock}" 
                                               Style="{StaticResource StatusInventoryTextStyle}" />
                                    </Border>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Stock Minimo"
                            ElementStyle="{StaticResource TextFillInventoryDataGrid}"
                            Binding="{Binding MiniumStock}"
                            Width="*" />

                        <DataGridTemplateColumn Header="Estado"
                            Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Border Style="{StaticResource StatusInventoryBorderStyle}">
                                        <TextBlock Text="{Binding StateStock}" 
                                               Style="{StaticResource StatusInventoryTextStyle}" />
                                    </Border>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Ultimos Movimientos"
                            Binding="{Binding LastMovement,StringFormat={}{0:dd/MM/yyyy}}"
                            ElementStyle="{StaticResource TextFillInventoryDataGrid}"
                            Width="*" />

                    </DataGrid.Columns>

                </DataGrid>

                <!--Mensaje que aparece cuando no se encontraron resultados despues de filtrar-->
                <Border  Width="auto" Height="auto" Grid.Row="1"
                    Background="White">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/View/Products/quitar-filtro.png" Width="150" Height="150"
                           HorizontalAlignment="Center"/>
                        <TextBlock Text="No hay stocks de productos que coincidan con los filtros" FontSize="26" 
                               Foreground="#1c4d8d" Margin="0,10,0,0"
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Reajuste los filtros para encontrar resultados"
                               FontSize="16" Foreground="#1c4d8d"
                               Margin="0,10,0,0"
                               FontWeight="Normal" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding InventoryItemsView.IsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!--Mensaje que aparece cuando no hay movimientos registrados-->
                <Border  Width="auto" Height="auto" Grid.Row="1"
                                Background="White">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/View/Products/caja.png" Width="150" Height="150"
                                       HorizontalAlignment="Center"/>
                        <TextBlock Text="No hay stocks de productos disponibles" FontSize="26" 
                                           Foreground="#1c4d8d" Margin="0,10,0,0"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Regista tus primeros movimientos para generar un stock."
                                           FontSize="16" Foreground="#1c4d8d"
                                           Margin="0,10,0,0"
                                           FontWeight="Normal" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding InventoryItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </Grid>

        <!--Pantalla de "Cargando..."-->
        <controls:LoadingViewControl
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="White" IsLoading="{Binding IsBusy}"
                    TextLoading="Cargando Inventarios Disponibles..."
                    TextColor="#BDBDBD"
                    ProgressColor="#1C4D8D"/>
    </Grid>
</Page>
