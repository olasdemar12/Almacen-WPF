<UserControl x:Class="Almacen_Sistema.UI.Dialogs.Product.DeleteProductDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Dialogs.Product"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Dialogs"
             d:DataContext="{d:DesignInstance Type=vm:DeleteProductViewModel,IsDesignTimeCreatable=False}"
             mc:Ignorable="d">
    <Grid>
        <controls:DeleteDialogControl Title="Eliminar Producto" Subtitle="¿Deseas eliminar la siguiente Producto?"
                                      Normal1="Se eliminará el Producto" Negrita1="{Binding ProductObject.ProductName}"
                                      Normal2="Los datos del stock y movimientos quedaran registrados."
                                      IsEnable="{Binding IsEnable}"
                                      IsLoading="{Binding IsLoading}"
                                      DeleteCommand="{Binding DeleteProductCommand}"
                                      CancelCommand="{Binding CloseDialogCommand}"/>
    </Grid>
</UserControl>
