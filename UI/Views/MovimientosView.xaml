<Page x:Class="Almacen_Sistema.UI.Views.MovimientosView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Almacen_Sistema.UI.Views"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:StockMasterControls"
      xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Pages"
      xmlns:helpers="clr-namespace:Almacen_Sistema.Resources.Helpers.EmptyStringText"
      d:DataContext="{d:DesignInstance Type=vm:MovementsViewModel,IsDesignTimeCreatable=False}"
      xmlns:converters="clr-namespace:Almacen_Sistema.Resources.Helpers.EmptyStringText"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MovimientosView">
    <Page.Resources>
        <converters:EmptyStringToTextConverter x:Key="EmptyStringToTextConverter" />
    </Page.Resources>
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Barra de busquedam filtros y botones para acciones: Entrada y Salida -->
            <Border Background="White" Grid.Row="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                    Width="auto" Height="80" CornerRadius="0,0,5,5"
                    Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" 
                                      Direction="270" 
                                      ShadowDepth="2" 
                                      Opacity="0.5" 
                                      BlurRadius="10" />
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Barra de Busqueda -->
                    <controls:SearchBarControl
                        Margin="5,15,5,15"
                        HintText="Buscar Producto"
                        SearchText="{Binding SearchProduct}"
                        SearchCommand="{Binding SearchProductsCommand}"/>

                    <!--Filtro de Tipo de Movimiento-->
                    <ComboBox Grid.Column="1" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                              Padding="15,10" Margin="5,15,5,15"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Tipo de Movimiento"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"
                              ItemsSource="{Binding MovementTypes}"
                              SelectedItem="{Binding SelectedMovementType, Mode=TwoWay}"/>
                    
                    <!--Intervalos de fechas: Fecha Inicio -->
                    <DatePicker Grid.Column="2" Style="{StaticResource CustomMaterialDatePickerStyle}"
                                Margin="5,15,5,15" materialDesign:HintAssist.Hint="Fecha de Inicio"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                SelectedDate="{Binding StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                DisplayDateEnd="{Binding EndDate}"/>

                    <!--Intervalos de fechas: Fecha Fin -->
                    <DatePicker Grid.Column="3" Style="{StaticResource CustomMaterialDatePickerStyle}"
                                Margin="5,15,5,15" materialDesign:HintAssist.Hint="Fecha de Fin"
                                materialDesign:TextFieldAssist.HasClearButton="True"
                                SelectedDate="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                DisplayDateStart="{Binding StartDate}"/>
                    
                    <!--Boton para registrar Entradas-->
                    <controls:IconTextButtonControl Grid.Column="4" 
                        Width="140" Height="50" Padding="0"
                        Margin="5,0,5,0"
                        Icon="Login" Text="Entrada"
                        ColorButton="#1c4d8d" ContentColorButton="White"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Command="{Binding EntryMovementCommand}"/>

                    <!--Boton para registrar Salida-->
                    <controls:IconTextButtonControl Grid.Column="5"
                        Margin="5,0,5,0" Padding="0"
                        Width="125" Height="50"
                        Icon="Logout" Text="Salida"
                        ColorButton="#1c4d8d" ContentColorButton="White"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Command="{Binding ExitMovementCommand}"/>
                </Grid>
                
            </Border>

            <!--Tabla quen muestra la lista de Movimientos-->
            <Border Grid.Row="1" Height="42"
                    VerticalAlignment="Top"
                    Background="#4A80C0"
                    Panel.ZIndex="0"/>
            
            <DataGrid x:Name="ProductsGrid" Grid.Row="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Style="{StaticResource DataGridStyleGeneral}"
                      ColumnHeaderStyle="{StaticResource DataGridHead}"
                      CellStyle="{StaticResource DataGridCellConfig}"
                      ItemsSource="{Binding TransactionHistoryViewItems}"
                      Padding="0,0,0,0"
          
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="1,1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                
                      RowHeight="60"
                      Panel.ZIndex="1"
                      Background="Transparent">

                <DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                        <Setter Property="IsEnabled" Value="True"/>
                        <Setter Property="Opacity" Value="1"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Confirmed}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="Opacity" Value="0.90"/>
                            </DataTrigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Fecha"
                            Binding="{Binding RegisterDate,StringFormat={}{0:dd/MM/yyyy}}"            
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*"/>

                    <DataGridTemplateColumn Header="Movimiento"
                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <Border Style="{StaticResource MovementBadgeBorderStyle}">
                                    <TextBlock Text="{Binding TypeMovement}" 
                                               Style="{StaticResource MovementBadgeTextStyle}" />
                                </Border>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Producto"
                            Binding="{Binding ProductName}" 
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*" />

                    <DataGridTemplateColumn Header="Cantidad"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <Border Style="{StaticResource MovementBadgeBorderStyle}">
                                    <TextBlock Text="{Binding Quantity}" 
                                               Style="{StaticResource MovementBadgeTextStyle}" />
                                </Border>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Notas"
                            Binding="{Binding Notes,Converter={StaticResource EmptyStringToTextConverter}}" 
                            ElementStyle="{StaticResource TextFillDataGrid}"
                            Width="*" />

                    <DataGridTemplateColumn Header="Acciones" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Width="40" Height="40" Margin="0,0,5,0" 
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            materialDesign:ButtonAssist.CornerRadius="10"
                                            Command="{Binding DataContext.ModificationEntryMovementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Foreground="#3F8CD9" ToolTip="Editar Registro">
                                        <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20" Foreground="#3F8CD9"/>
                                    </Button>

                                    <Button Width="35" Height="35"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            materialDesign:ButtonAssist.CornerRadius="10"
                                            Margin="0,0,5,0"
                                            materialDesign:RippleAssist.Feedback="Red"
                                            Command="{Binding DataContext.RemoveMovementRegistedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Foreground="Red" ToolTip="Eliminar Registro">
                                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" Foreground="Red"/>
                                    </Button>

                                    <CheckBox HorizontalAlignment="Center" Height="80" Width="80"
                                              VerticalAlignment="Center"
                                              ToolTip="Confirmar Movimiento"
                                              IsChecked="{Binding Confirmed, Mode=OneWay}"
                                              Command="{Binding DataContext.ConfirmMovementCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                </DataGrid.Columns>

            </DataGrid>

        </Grid>
    </Grid>
</Page>
