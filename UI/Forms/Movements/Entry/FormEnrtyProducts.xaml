<UserControl x:Class="Almacen_Sistema.UI.Forms.Movements.Entry.FormEnrtyProducts"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Forms.Movements.Entry"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid IsEnabled="{Binding IsEnable}">

        <controls:PanelControl Title="Registrar Entrada" 
                            ShowBackButton="True"
                            ShowCloseButton="False"
                            Width="500"
                            Height="600">
            <StackPanel>
                <Label Content="Producto Seleccionado" 
                      FontSize="16" FontWeight="Normal"
                      FontFamily="Segoe UI" Foreground="#212121"
                      Margin="10,10,10,0"/>


                <Border Margin="10" Height="45" Background="#e0e0e0"
                        BorderBrush="#bdbdbd" BorderThickness="2"
                        CornerRadius="5">
                    <TextBlock Text="Coca Cola 600ml" FontSize="16" Margin="10"
                               Foreground="#212121" FontFamily="Segoe UI"/>
                </Border>
                
                
                <Label Content="Fecha y Hora del registro"
                        FontSize="16" FontWeight="Normal"
                        FontFamily="Segoe UI" Foreground="#212121"
                        Margin="10,10,10,0"/>


                <Border Margin="10" Height="45" Background="#e0e0e0"
                 BorderBrush="#bdbdbd" BorderThickness="2"
                    CornerRadius="5">
                    <TextBlock Text="2026-02-20 -- 10:30:00" FontSize="16" Margin="10"
                    Foreground="#212121" FontFamily="Segoe UI"/>
                </Border>
                
                
                <Label Content="Unidades Recibidas"
                FontSize="16" FontWeight="Normal"
                FontFamily="Segoe UI" Foreground="#212121"
                Margin="10,10,10,0"/>

                <StackPanel Orientation="Horizontal"  HorizontalAlignment="Right" >

                    <TextBlock Text="100" FontSize="16" Margin="10"
                        Foreground="#212121" FontFamily="Segoe UI"/>
                    <StackPanel Orientation="Horizontal"  HorizontalAlignment="Right">
                        <Button Content="-" Width="50" 
                        Height="40" Margin="0" 
                        Foreground="#212121"
                        FontFamily="Segoe UI"
                        Background="White"
                        BorderBrush="#bdbdbd" />

                        <Button Content="+" Width="50" 
                         Height="40" Margin="0,0,15,0" 
                         Foreground="#212121"
                         FontFamily="Segoe UI"
                         Background="White"
                        BorderBrush="#bdbdbd"
                         />
                    </StackPanel>

                </StackPanel>

                <Label Content="Observaciones del Registro:"
                       Foreground="#212121"
                       FontFamily="Segoe UI"
                       FontSize="16" Margin="10,10,10,0"/>
                <TextBox  Height="130" AcceptsReturn="True" Margin="10,0,10,0" 
                          Foreground="#212121" FontFamily="Segoe UI" FontSize="16"
                          Text=""
                          Style="{StaticResource MaterialDesignOutlinedTextBox}"
                          Padding="10"
                          materialDesign:ValidationAssist.Background="White"
                          TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <!--Botones de acciones-->
                <StackPanel Orientation="Horizontal"  HorizontalAlignment="Right">
                    <Button Content="Cancelar" Grid.Column="0" 
                            Background="#bdbdbd"
                            BorderBrush="#bdbdbd"
                            Foreground="White"
                            FontSize="16"
                            FontFamily="Segoe UI"
                            Margin="5" Height="40"/>
                    
                    
                    <Button Content="Registrar Entrada" Grid.Column="1" 
                            Margin="20" Height="40" Background="#1976D2"
                            Foreground="White"
                            FontSize="16"
                            FontFamily="Segoe UI"/>
                </StackPanel>


            </StackPanel>
      
        </controls:PanelControl>
    </Grid>
</UserControl>
