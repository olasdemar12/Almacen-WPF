<UserControl x:Class="Almacen_Sistema.UI.Dialogs.Login.ErrorLoginDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Dialogs.Login"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#152B4D" CornerRadius="8,8,0,0" Padding="15">
            <TextBlock Text="{Binding Titulo}" 
                       Foreground="White" 
                       FontWeight="Bold" 
                       FontSize="16" 
                       HorizontalAlignment="Left"
                       Margin="10,0,0,0"/>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="0,0,8,8" Padding="20,30,20,20">
            <StackPanel>
                <TextBlock Text="{Binding Mensaje}" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center" 
                           FontSize="14" 
                           Foreground="#333333" 
                           Margin="0,0,0,25"/>

                <Button Content="Aceptar" 
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                        HorizontalAlignment="Stretch"
                        Background="#96D1F8" 
                        BorderBrush="#96D1F8" 
                        Foreground="#152B4D" 
                        FontWeight="Bold"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Width="auto"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
