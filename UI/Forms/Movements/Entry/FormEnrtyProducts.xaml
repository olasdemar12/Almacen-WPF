<UserControl x:Class="Almacen_Sistema.UI.Forms.Movements.Entry.FormEnrtyProducts"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Forms.Movements.Entry"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <Grid IsEnabled="{Binding IsEnable}">

        <controls:PanelControl Title="Registrar Entrada" 
                            ShowBackButton="True"
                            ShowCloseButton="False"
                            Width="500"
                            Height="575">
            <StackPanel>
                <!--Producto seleccionado-->
                <Label Content="Producto Seleccionado" 
                      FontSize="16" FontWeight="Normal"
                      FontFamily="Segoe UI" Foreground="#212121"
                      Margin="10,10,10,0"/>
                <Border Margin="10,0,10,0" Height="45" Background="#e0e0e0"
                        BorderBrush="#bdbdbd" BorderThickness="2"
                        CornerRadius="5">
                    <TextBlock Text="Coca Cola 600ml" FontSize="16" Margin="10"
                               Foreground="#212121" FontFamily="Segoe UI"/>
                </Border>

                <!--Fecha y Hora del registro de entrada-->
                <Label Content="Fecha y Hora del registro"
                        FontSize="16" FontWeight="Normal"
                        FontFamily="Segoe UI" Foreground="#212121"
                        Margin="10,10,10,0"/>
                <Border Margin="10,0,10,0" Height="45" Background="#e0e0e0"
                 BorderBrush="#bdbdbd" BorderThickness="2"
                    CornerRadius="5">
                    <TextBlock Text="2026-02-20 -- 10:30:00" FontSize="16" Margin="10"
                    Foreground="#212121" FontFamily="Segoe UI"/>
                </Border>

                <!--Registro de unidades, piezas o kilogramos registrados-->
                <TextBlock Text="Unidades Recibidas" Foreground="#212121" FontSize="16"
                                   FontFamily="Segoe UI" Margin="10,10,0,0"/>
                <TextBox Width="auto" Height="50"
                     BorderBrush="#bdbdbd" Background="White" BorderThickness="2"
                     Margin="10,5,10,10"
                     FontFamily="Segoe UI"
                     FontSize="16"
                     Padding="13"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Simulacion"
                     materialDesign:HintAssist.IsFloating="False"
                     materialDesign:ValidationAssist.Background="White"/>


                <!--Observaciones del Registro-->
                <TextBlock Text="Observaciones del Registro" Foreground="#212121" FontSize="16"
                                   FontFamily="Segoe UI" Margin="10,0,0,0"/>
                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
             BorderBrush="#bdbdbd" Background="White" BorderThickness="2"         
             materialDesign:HintAssist.Hint="(Opcional)"
             materialDesign:HintAssist.IsFloating="False"
             Margin="10,5,10,0" FontFamily="Segoe UI" FontSize="16"
             materialDesign:ValidationAssist.Background="White"
             AcceptsReturn="True" Padding="10"
             TextWrapping="Wrap" VerticalContentAlignment="Top"
             VerticalScrollBarVisibility="Auto"
             MinHeight="130"/>

                <!--Botones para cancelar o guardar el registro-->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                    <Button Content="Cancelar" Height="50" Padding="10,0,10,0" Background="#BDBDBD"
                        BorderBrush="#BDBDBD" Foreground="White" FontFamily="Segoe UI"
                        FontWeight="Normal" FontSize="22" materialDesign:ButtonAssist.CornerRadius="5"/>

                    <controls:LoadingButtonControl Width="auto" Height="50"
                                                   ButtonContent="Registrar Entrada"
                                                   IsLoading="False"
                                                   Margin="5,0,0,0"
                                                   Padding="10,0,10,0"
                                                   ButtonColor="#1c4d8d"
                                                   Foreground="White"
                                                   FontSize="22"
                                                   FontWeight="Normal"/>
                </StackPanel>

            </StackPanel>
      
        </controls:PanelControl>
    </Grid>
</UserControl>
