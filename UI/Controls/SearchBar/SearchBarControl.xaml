<UserControl x:Class="StockMasterControls.SearchBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" x:Name="Root">
    <Grid>

        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 materialDesign:HintAssist.Hint="{Binding HintText, ElementName=Root}"
                 materialDesign:HintAssist.HintPaddingBrush="White"
                 materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
                 Text="{Binding SearchText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                 Padding="15,10,40,10"
                 FontSize="16"
                 FontFamily="Segoe UI"
                 BorderBrush="#bdbdbd"
                 KeyDown="OnKeyDown"/>

        <Button Style="{StaticResource MaterialDesignIconButton}"
                Command="{Binding SearchCommand, ElementName=Root}"
                HorizontalAlignment="Right"
                Margin="0,0,5,0"
                Width="32" Height="32"
                ToolTip="Ejecutar búsqueda"
                Click="Button_Click">
            <materialDesign:PackIcon Kind="Magnify" Width="20" Height="20" Foreground="#bdbdbd"/>
        </Button>
    </Grid>
</UserControl>
