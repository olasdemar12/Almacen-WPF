<UserControl x:Class="Almacen_Sistema.UI.Panels.Movements.ProductSelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Panels.Movements"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Panels"
             d:DataContext="{d:DesignInstance Type=vm:ProductSelectionViewModel,IsDesignTimeCreatable=False}"
             mc:Ignorable="d">
    <controls:PanelControl Width="500" Height="600" Title="Productos Registrados"
                               ShowCloseButton="True" ShowBackButton="False">
        <Grid>

            <!--Contenido del Panel-->
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--Seccion para buscar y filtrar productos-->
                <Grid Grid.Row="0" Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <!--Barra de busqueda-->
                    <controls:SearchBarControl Grid.Column="0" HintText="Buscar Producto..."
                                               SearchText="{Binding SearchProduct,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                    <!--Filtro de categorias-->
                    <ComboBox Grid.Column="1" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" Width="150"
                              Padding="15,10" Margin="10,0,0,0"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Categorías"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"
                              materialDesign:ComboBoxAssist.MaxLength="20"
                              ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding SelectedCategory,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="IdCategoria">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NombreCategoria}"
                                           TextTrimming="CharacterEllipsis"
                                            Width="150"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                </Grid>

                <!--Lista para mostrar los productos registrados-->
                <Border Grid.Row="1" Height="42" Margin="5"
                    VerticalAlignment="Top" 
                    Background="#4A80C0"
                    Panel.ZIndex="0"/>
                <DataGrid Grid.Row="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Style="{StaticResource DataGridStyleGeneral}"
                      ColumnHeaderStyle="{StaticResource DataGridHead}"
                      CellStyle="{StaticResource DataGridCellConfig}"
                      RowStyle="{StaticResource DataGridRowConfig}"
                      ItemsSource="{Binding ProductsViewItems}"
                      SelectedItem="{Binding SelectedProduct,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                      Padding="0,0,0,0" Margin="5"
                      
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="1,1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                            
                      RowHeight="60"
                      Panel.ZIndex="1"
                      Background="Transparent">


                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Producto"
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Binding="{Binding ProductName}"
                                        Width="*" />

                        <DataGridTextColumn Header="Categoría" 
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Binding="{Binding CategoryName}"
                                        Width="*" />

                        <DataGridTextColumn Header="Código de Barras"
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Binding="{Binding BarCode}"
                                        Width="*" />
                    </DataGrid.Columns>

                </DataGrid>

                <!--Mensaje que aparece cuando no hay Productos registrados en la Base de Datos-->
                <Border  Width="auto" Height="auto" Grid.Row="1"
                                Background="White">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/View/Products/caja.png" Width="150" Height="150"
                                       HorizontalAlignment="Center"/>
                        <TextBlock Text="No hay productos registrados" FontSize="26" 
                                           Foreground="#1c4d8d" Margin="0,10,0,0"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Registre nuevos productos en el módulo de productos antes de realizar un movimiento de entrada"
                                           FontSize="16" Foreground="#1c4d8d"
                                           Margin="0,10,0,0" TextWrapping="Wrap" TextAlignment="Center"
                                           FontWeight="Normal" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Products.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!--Mensaje que aparece cuando no se encontraron resultados despues de filtrar-->
                <Border  Width="auto" Height="auto" Grid.Row="1"
                    Background="White">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/View/Products/quitar-filtro.png" Width="150" Height="150"
                           HorizontalAlignment="Center"/>
                        <TextBlock Text="No se encontraron resulados." FontSize="26" 
                               Foreground="#1c4d8d" Margin="0,10,0,0"
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="No hay resultados que coincidan con la busqueda o el filtro aplicado."
                               FontSize="16" Foreground="#1c4d8d" 
                               Margin="10,10,10,0" TextWrapping="Wrap" TextAlignment="Center"
                               FontWeight="Normal" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsResultsEmpty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!--Pantalla de Cargando con el Mensaje de "Cargando Resultados":-->
                <controls:LoadingViewControl Grid.Row="1" Panel.ZIndex="3"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="White" IsLoading="{Binding IsLoadingResults}"
                    TextLoading="Cargando Resultados..."
                    TextColor="#BDBDBD" Margin="6,47,6,6"
                    ProgressColor="#1C4D8D"/>

            </Grid>
            
            <!--Mensaje de "Cargando Productos":-->
            <controls:LoadingViewControl 
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="White" IsLoading="{Binding IsLoadingProducts}"
                    TextLoading="Cargando Productos..."
                    TextColor="#BDBDBD"
                    ProgressColor="#1C4D8D"/>

        </Grid>

    </controls:PanelControl>
</UserControl>
