<Page x:Class="Almacen_Sistema.UI.Views.ProductosView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Almacen_Sistema.UI.Views"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:controls="clr-namespace:StockMasterControls"
      xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Pages"
      d:DataContext="{d:DesignInstance Type=vm:ProductViewModel,IsDesignTimeCreatable=False}"
      mc:Ignorable="d" 
      Background="Transparent">
    <Grid>
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Barra de busqueda, filtros y botones de categoria y nuevo producto -->
            <Border Background="White" Grid.Row="0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                    Width="auto" Height="80" CornerRadius="0,0,5,5"
                    Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect Color="Black" 
                                      Direction="270" 
                                      ShadowDepth="2" 
                                      Opacity="0.5" 
                                      BlurRadius="10" />
                </Border.Effect>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Barra de Busqueda -->
                    <controls:SearchBarControl
                        Grid.Column="0"
                        Margin="10,15,10,15"
                        HintText="Buscar Producto"
                        SearchText="{Binding SearchProduct}"
                        SearchCommand="{Binding SearchProductsCommand}"/>

                    <!--Filtro para Categorias-->
                    <ComboBox Grid.Column="1" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                              Padding="15,10" Margin="10,15,10,15"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Categorías"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"
                              ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding SelectedCategory,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="IdCategoria"
                              DisplayMemberPath="NombreCategoria"/>

                    <!--Filtro para tipo de venta-->
                    <ComboBox Grid.Column="2" FontSize="16" FontFamily="Segoe UI"
                              BorderBrush="#bdbdbd" HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" 
                              Padding="15,10" Margin="10,15,5,15"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Tipo de Venta"
                              materialDesign:HintAssist.Foreground="#212121"
                              materialDesign:HintAssist.HintPaddingBrush="White"
                              materialDesign:TextFieldAssist.HasClearButton="True"
                              ItemsSource="{Binding Source={x:Static controls:NotificationServiceControl.Instance}, Path=SaleType}"
                              SelectedItem="{Binding SelectedTypeSale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--Boton para agregar un nuevo Producto-->
                    <controls:IconTextButtonControl Grid.Column="3"
                        Width="130" Height="50" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Margin="5,15,0,15"
                        Icon="Plus" Text="Nuevo"
                        ColorButton="#1c4d8d" ContentColorButton="White"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Command="{Binding ProductAddCommand}"/>

                    <!--Boton para abrir el panel de categorias-->
                    <controls:IconTextButtonControl Grid.Column="4"
                        Width="180" Height="50" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Margin="10,15,10,15"
                        Icon="ViewGridOutline" Text="Categorias"
                        ColorButton="#1c4d8d" ContentColorButton="White"
                        materialDesign:ButtonAssist.CornerRadius="10"
                        Command="{Binding CategoryManagementCommand}"/>
                    
                </Grid>

            </Border>
            

            <!--Tabla para mostrar la lista de Productos-->
            <Border Grid.Row="1" Height="42"
                    VerticalAlignment="Top"
                    Background="#4A80C0"
                    Panel.ZIndex="0"/>
            <DataGrid x:Name="ProductsGrid" Grid.Row="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Style="{StaticResource DataGridStyleGeneral}"
                      ColumnHeaderStyle="{StaticResource DataGridHead}"
                      CellStyle="{StaticResource DataGridCellConfig}"
                      RowStyle="{StaticResource DataGridRowConfig}"
                      ItemsSource="{Binding ProductsViewItems}"
                      Padding="0,0,0,0"
                      
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="1,1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                            
                      RowHeight="60"
                      Panel.ZIndex="1"
                      Background="Transparent">


                <DataGrid.Columns>

                    <DataGridTextColumn Header="Nombre" 
                                        Binding="{Binding ProductName}"
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Width="*" />

                    <DataGridTextColumn Header="Categoría" 
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Binding="{Binding CategoryName}" 
                                        Width="*" />

                    <DataGridTextColumn Header="Código de Barras"
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Binding="{Binding BarCode}" 
                                        Width="*" />

                    <DataGridTextColumn Header="Precio de Venta"
                                        ElementStyle="{StaticResource TextFillDataGrid}"
                                        Binding="{Binding SalePrice, StringFormat={}{0:C}}" 
                                        Width="*" />

                    <DataGridTemplateColumn Header="Acciones" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Width="40" Height="40" Margin="0,0,5,0"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="10"
                                                        Foreground="#3F8CD9"
                                                        Command="{Binding DataContext.EditProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20" Foreground="#3F8CD9"/>
                                    </Button>

                                    <Button Width="35" Height="35"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="10"
                                                        materialDesign:RippleAssist.Feedback="Red"
                                                        Foreground="Red"
                                                        Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" Foreground="Red"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

            </DataGrid>
            
            <!--Mensaje que aparece cuando no hay Productos registrados-->
            <Border  Width="auto" Height="auto" Grid.Row="1"
                                Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="/Assets/View/Products/caja.png" Width="150" Height="150"
                                       HorizontalAlignment="Center"/>
                    <TextBlock Text="No hay productos registrados" FontSize="26" 
                                           Foreground="#1c4d8d" Margin="0,10,0,0"
                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Presiona el botón de Nuevo para crear tu primer producto"
                                           FontSize="16" Foreground="#1c4d8d"
                                           Margin="0,10,0,0"
                                           FontWeight="Normal" HorizontalAlignment="Center"/>
                </StackPanel>

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Products.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!--Mensaje que aparece cuando no se encontraron resultados despues de filtrar-->
            <Border  Width="auto" Height="auto" Grid.Row="1"
                    Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="/Assets/View/Products/quitar-filtro.png" Width="150" Height="150"
                           HorizontalAlignment="Center"/>
                    <TextBlock Text="No hay productos que coincidan con los filtros" FontSize="26" 
                               Foreground="#1c4d8d" Margin="0,10,0,0"
                               FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Reajuste los filtros para encontrar resultados"
                               FontSize="16" Foreground="#1c4d8d"
                               Margin="0,10,0,0"
                               FontWeight="Normal" HorizontalAlignment="Center"/>
                </StackPanel>

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsFilterActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
        </Grid>

        <!--Pantalla de "Cargando..."-->
        <controls:LoadingViewControl
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="White" IsLoading="{Binding IsBusy}"
                    TextLoading="Cargando Productos..."
                    TextColor="#BDBDBD"
                    ProgressColor="#1C4D8D"/>
    </Grid>
</Page>