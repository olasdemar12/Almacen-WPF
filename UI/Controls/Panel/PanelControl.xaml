<UserControl x:Class="StockMasterControls.PanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Converters"
             mc:Ignorable="d"
             x:Name="Root">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#1C4D8D"
                CornerRadius="10,10,0,0">
            <Grid>
                <Button Width="40" Height="40" Margin="5"
                        Style="{StaticResource MaterialDesignIconButton}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Visibility="{Binding ShowBackButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="ArrowBack"
                                             Width="30"
                                             Height="30"
                                             Foreground="White"/>
                </Button>

                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Margin="55,0,0,0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           FontSize="18"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           Foreground="White"/>

                <Button Width="40" Height="40" Margin="5" Padding="0"
                        Style="{StaticResource MaterialDesignIconButton}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Visibility="{Binding ShowCloseButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}">
                    <materialDesign:PackIcon Kind="Close"
                                             Width="30"
                                             Height="30"
                                             Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- Cuerpo -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="0,0,10,10">
            <ContentPresenter Content="{Binding PanelContent, ElementName=Root}"/>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
        </Border>
    </Grid>
</UserControl>
