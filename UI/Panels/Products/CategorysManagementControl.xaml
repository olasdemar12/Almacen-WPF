<UserControl x:Class="Almacen_Sistema.UI.Panels.Products.CategorysManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Almacen_Sistema.UI.Panels.Products"
             xmlns:controls="clr-namespace:StockMasterControls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Almacen_Sistema.MVVM.ViewModels.Panels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:CategorysManagementVM,IsDesignTimeCreatable=False}"
             d:DesignHeight="1000" d:DesignWidth="800">
    <Grid IsEnabled="{Binding IsEnable}">
        <controls:PanelControl Title="Gestion de Categorías" 
                                   ShowBackButton="False"
                                   ShowCloseButton="True"
                                   Width="500"
                                   Height="600">
            <Grid>

                <Grid>
                    <!--Definicion de filas-->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--Boton para agregar categorias-->
                    <controls:IconTextButtonControl Grid.Row="0"
                                                Width="220" Height="50"
                                                HorizontalAlignment="Left"
                                                Margin="10,5,0,0"
                                                Icon="Plus" Text="Nueva Categoría"
                                                ColorButton="#1c4d8d" ContentColorButton="White"
                                                materialDesign:ButtonAssist.CornerRadius="10"
                                                Command="{Binding FormCategoryActionCommand}"
                                                CommandParameter="FormCategoryAction"/>

                    <!--DataGrid de Categoria-->
                    <Grid  Grid.Row="1" Margin="5">
                        <Border Height="42"
                                VerticalAlignment="Top"
                                Background="#4A80C0"
                                Panel.ZIndex="0"/>
                        <DataGrid
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Style="{StaticResource DataGridStyleGeneral}"
                              ColumnHeaderStyle="{StaticResource DataGridHead}"
                              CellStyle="{StaticResource DataGridCellConfig}"
                              RowStyle="{StaticResource DataGridRowConfig}"
                              ItemsSource="{Binding Categories}"
                            
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              VirtualizingPanel.CacheLength="1,1"
                              VirtualizingPanel.CacheLengthUnit="Page"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                            
                              RowHeight="55"
                              Panel.ZIndex="1"
                              Background="Transparent">
                            
                            <!--Declaracion de Columnas: Nombre, Total Productos y Acciones-->
                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Nombre" Width="*"
                                                Binding="{Binding NombreCategoria}"
                                                ElementStyle="{StaticResource TextFillDataGrid}"/>

                                <DataGridTextColumn Header="Total Productos" Width="*"
                                                Binding="{Binding TotalProductos}"
                                                ElementStyle="{StaticResource TextFillDataGrid}"/>

                                <DataGridTemplateColumn Header="Acciones" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                                <!--Boton Editar-->
                                                <Button Width="35" Height="35" Margin="0,0,5,0"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="10"
                                                        Foreground="#3F8CD9"
                                                        Command="{Binding DataContext.EditCategoryActionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Pencil" Width="20" Height="20" Foreground="#3F8CD9"/>
                                                </Button>

                                                <!--Boton Eliminar-->
                                                <Button Width="35" Height="35"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        materialDesign:ButtonAssist.CornerRadius="10"
                                                        materialDesign:RippleAssist.Feedback="Red"
                                                        Foreground="Red"
                                                        Command="{Binding DataContext.DeleteCategoryActionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Delete" Width="20" Height="20" Foreground="Red"/>
                                                </Button>
                                                
                                            </StackPanel>

                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
                
                <!--Pantalla de "Cargando..."-->
                <controls:LoadingViewControl
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="White" IsLoading="{Binding IsBusy}"
                    TextLoading="Cargando Categorías..."
                    TextColor="#BDBDBD"
                    ProgressColor="#1C4D8D"/>
            </Grid>
        </controls:PanelControl>

    </Grid>
</UserControl>
